{
  "$defs": {
    "ArtifactInput": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "revision": {
          "title": "Revision",
          "type": "integer"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "path",
        "revision",
        "sha256"
      ],
      "title": "ArtifactInput",
      "type": "object"
    },
    "ArtifactMetadata": {
      "additionalProperties": false,
      "properties": {
        "content_sha256": {
          "default": "",
          "title": "Content Sha256",
          "type": "string"
        }
      },
      "title": "ArtifactMetadata",
      "type": "object"
    },
    "ArtifactStatus": {
      "enum": [
        "accepted",
        "complete",
        "approved",
        "validated",
        "ready",
        "completed",
        "passed",
        "failed",
        "skipped",
        "ready_for_human_review",
        "human_required"
      ],
      "title": "ArtifactStatus",
      "type": "string"
    },
    "ArtifactType": {
      "enum": [
        "goal",
        "repository_snapshot",
        "specification",
        "verification_plan",
        "execution_plan",
        "task",
        "worker_request",
        "worker_result",
        "integration",
        "gate_report",
        "tool_request",
        "tool_result",
        "repair_request",
        "repair_result",
        "review_report",
        "goal_satisfaction_report",
        "evidence_bundle",
        "release_manifest"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "Producer": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/ProducerKind"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "title": "Producer",
      "type": "object"
    },
    "ProducerKind": {
      "enum": [
        "human",
        "system",
        "model",
        "tool"
      ],
      "title": "ProducerKind",
      "type": "string"
    },
    "ToolResultData": {
      "additionalProperties": false,
      "properties": {
        "artifact_hashes": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Artifact Hashes",
          "type": "object"
        },
        "artifacts": {
          "items": {
            "type": "string"
          },
          "title": "Artifacts",
          "type": "array"
        },
        "check_id": {
          "title": "Check Id",
          "type": "string"
        },
        "command": {
          "title": "Command",
          "type": "string"
        },
        "duration_ms": {
          "default": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "evidence_paths": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Paths",
          "type": "array"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exit Code"
        },
        "failure_fingerprint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failure Fingerprint"
        },
        "observations": {
          "additionalProperties": true,
          "title": "Observations",
          "type": "object"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "skipped",
            "timeout"
          ],
          "title": "Status",
          "type": "string"
        },
        "stderr_path": {
          "title": "Stderr Path",
          "type": "string"
        },
        "stdout_path": {
          "title": "Stdout Path",
          "type": "string"
        },
        "tool": {
          "title": "Tool",
          "type": "string"
        },
        "tool_run_id": {
          "title": "Tool Run Id",
          "type": "string"
        }
      },
      "required": [
        "tool_run_id",
        "check_id",
        "tool",
        "status",
        "command",
        "stdout_path",
        "stderr_path"
      ],
      "title": "ToolResultData",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_type": {
      "$ref": "#/$defs/ArtifactType"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/ToolResultData"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/ArtifactInput"
      },
      "title": "Inputs",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/ArtifactMetadata"
    },
    "producer": {
      "$ref": "#/$defs/Producer"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactStatus"
        },
        {
          "type": "string"
        }
      ],
      "title": "Status"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "run_id",
    "revision",
    "status",
    "created_at",
    "producer",
    "data"
  ],
  "title": "ToolResultArtifact",
  "type": "object"
}
