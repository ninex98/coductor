{
  "$defs": {
    "ArtifactInput": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "revision": {
          "title": "Revision",
          "type": "integer"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "path",
        "revision",
        "sha256"
      ],
      "title": "ArtifactInput",
      "type": "object"
    },
    "ArtifactMetadata": {
      "additionalProperties": false,
      "properties": {
        "content_sha256": {
          "default": "",
          "title": "Content Sha256",
          "type": "string"
        }
      },
      "title": "ArtifactMetadata",
      "type": "object"
    },
    "ArtifactStatus": {
      "enum": [
        "accepted",
        "complete",
        "approved",
        "validated",
        "ready",
        "completed",
        "passed",
        "failed",
        "skipped",
        "ready_for_human_review",
        "human_required"
      ],
      "title": "ArtifactStatus",
      "type": "string"
    },
    "ArtifactType": {
      "enum": [
        "goal",
        "repository_snapshot",
        "specification",
        "verification_plan",
        "execution_plan",
        "task",
        "worker_request",
        "worker_result",
        "integration",
        "gate_report",
        "tool_request",
        "tool_result",
        "repair_request",
        "repair_result",
        "review_report",
        "goal_satisfaction_report",
        "evidence_bundle",
        "release_manifest"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "GoalCriterionResult": {
      "additionalProperties": false,
      "properties": {
        "criterion_id": {
          "title": "Criterion Id",
          "type": "string"
        },
        "evidence": {
          "items": {
            "type": "string"
          },
          "title": "Evidence",
          "type": "array"
        },
        "missing_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Missing Evidence",
          "type": "array"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "status": {
          "enum": [
            "satisfied",
            "not_satisfied",
            "uncertain"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "criterion_id",
        "status",
        "reason"
      ],
      "title": "GoalCriterionResult",
      "type": "object"
    },
    "GoalSatisfactionReportData": {
      "additionalProperties": false,
      "properties": {
        "criterion_results": {
          "items": {
            "$ref": "#/$defs/GoalCriterionResult"
          },
          "title": "Criterion Results",
          "type": "array"
        },
        "missing_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Missing Evidence",
          "type": "array"
        },
        "repair_recommendation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repair Recommendation"
        },
        "requires_human": {
          "default": false,
          "title": "Requires Human",
          "type": "boolean"
        },
        "requires_repair": {
          "default": false,
          "title": "Requires Repair",
          "type": "boolean"
        },
        "verdict": {
          "enum": [
            "satisfied",
            "not_satisfied",
            "uncertain"
          ],
          "title": "Verdict",
          "type": "string"
        }
      },
      "required": [
        "verdict"
      ],
      "title": "GoalSatisfactionReportData",
      "type": "object"
    },
    "Producer": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/ProducerKind"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "title": "Producer",
      "type": "object"
    },
    "ProducerKind": {
      "enum": [
        "human",
        "system",
        "model",
        "tool"
      ],
      "title": "ProducerKind",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_type": {
      "$ref": "#/$defs/ArtifactType"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/GoalSatisfactionReportData"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/ArtifactInput"
      },
      "title": "Inputs",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/ArtifactMetadata"
    },
    "producer": {
      "$ref": "#/$defs/Producer"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactStatus"
        },
        {
          "type": "string"
        }
      ],
      "title": "Status"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "run_id",
    "revision",
    "status",
    "created_at",
    "producer",
    "data"
  ],
  "title": "GoalSatisfactionReportArtifact",
  "type": "object"
}
