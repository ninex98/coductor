{
  "$defs": {
    "ArtifactInput": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "revision": {
          "title": "Revision",
          "type": "integer"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "path",
        "revision",
        "sha256"
      ],
      "title": "ArtifactInput",
      "type": "object"
    },
    "ArtifactMetadata": {
      "additionalProperties": false,
      "properties": {
        "content_sha256": {
          "default": "",
          "title": "Content Sha256",
          "type": "string"
        }
      },
      "title": "ArtifactMetadata",
      "type": "object"
    },
    "ArtifactStatus": {
      "enum": [
        "accepted",
        "complete",
        "approved",
        "validated",
        "ready",
        "completed",
        "passed",
        "failed",
        "skipped",
        "ready_for_human_review",
        "human_required"
      ],
      "title": "ArtifactStatus",
      "type": "string"
    },
    "ArtifactType": {
      "enum": [
        "goal",
        "repository_snapshot",
        "specification",
        "execution_plan",
        "task",
        "worker_request",
        "worker_result",
        "integration",
        "gate_report",
        "repair_request",
        "repair_result",
        "review_report",
        "evidence_bundle",
        "release_manifest"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "ContractArtifact": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "json_schema",
            "openapi",
            "event_schema",
            "type_definition"
          ],
          "title": "Kind",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "producer_task_id": {
          "title": "Producer Task Id",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "kind",
        "sha256",
        "producer_task_id"
      ],
      "title": "ContractArtifact",
      "type": "object"
    },
    "Producer": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/ProducerKind"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "title": "Producer",
      "type": "object"
    },
    "ProducerKind": {
      "enum": [
        "human",
        "system",
        "model",
        "tool"
      ],
      "title": "ProducerKind",
      "type": "string"
    },
    "TaskData": {
      "additionalProperties": false,
      "properties": {
        "acceptance_criteria": {
          "items": {
            "type": "string"
          },
          "title": "Acceptance Criteria",
          "type": "array"
        },
        "allowed_paths": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Paths",
          "type": "array"
        },
        "contracts": {
          "items": {
            "$ref": "#/$defs/ContractArtifact"
          },
          "title": "Contracts",
          "type": "array"
        },
        "depends_on": {
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "expected_outputs": {
          "items": {
            "type": "string"
          },
          "title": "Expected Outputs",
          "type": "array"
        },
        "forbidden_paths": {
          "items": {
            "type": "string"
          },
          "title": "Forbidden Paths",
          "type": "array"
        },
        "global_context": {
          "items": {
            "type": "string"
          },
          "title": "Global Context",
          "type": "array"
        },
        "objective": {
          "title": "Objective",
          "type": "string"
        },
        "quality_gates": {
          "items": {
            "type": "string"
          },
          "title": "Quality Gates",
          "type": "array"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "task_id": {
          "title": "Task Id",
          "type": "string"
        },
        "upstream_artifacts": {
          "items": {
            "type": "string"
          },
          "title": "Upstream Artifacts",
          "type": "array"
        }
      },
      "required": [
        "task_id",
        "objective",
        "role"
      ],
      "title": "TaskData",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_type": {
      "$ref": "#/$defs/ArtifactType"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/TaskData"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/ArtifactInput"
      },
      "title": "Inputs",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/ArtifactMetadata"
    },
    "producer": {
      "$ref": "#/$defs/Producer"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactStatus"
        },
        {
          "type": "string"
        }
      ],
      "title": "Status"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "run_id",
    "revision",
    "status",
    "created_at",
    "producer",
    "data"
  ],
  "title": "TaskArtifact",
  "type": "object"
}
