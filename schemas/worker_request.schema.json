{
  "$defs": {
    "ArtifactInput": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "revision": {
          "title": "Revision",
          "type": "integer"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "path",
        "revision",
        "sha256"
      ],
      "title": "ArtifactInput",
      "type": "object"
    },
    "ArtifactMetadata": {
      "additionalProperties": false,
      "properties": {
        "content_sha256": {
          "default": "",
          "title": "Content Sha256",
          "type": "string"
        }
      },
      "title": "ArtifactMetadata",
      "type": "object"
    },
    "ArtifactStatus": {
      "enum": [
        "accepted",
        "complete",
        "approved",
        "validated",
        "ready",
        "completed",
        "passed",
        "failed",
        "skipped",
        "ready_for_human_review",
        "human_required"
      ],
      "title": "ArtifactStatus",
      "type": "string"
    },
    "ArtifactType": {
      "enum": [
        "goal",
        "repository_snapshot",
        "specification",
        "verification_plan",
        "execution_plan",
        "task",
        "worker_request",
        "worker_result",
        "integration",
        "gate_report",
        "tool_request",
        "tool_result",
        "repair_request",
        "repair_result",
        "review_report",
        "goal_satisfaction_report",
        "evidence_bundle",
        "release_manifest"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "Producer": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/ProducerKind"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "title": "Producer",
      "type": "object"
    },
    "ProducerKind": {
      "enum": [
        "human",
        "system",
        "model",
        "tool"
      ],
      "title": "ProducerKind",
      "type": "string"
    },
    "SandboxMode": {
      "enum": [
        "read_only",
        "workspace_write"
      ],
      "title": "SandboxMode",
      "type": "string"
    },
    "WorkerRequestData": {
      "additionalProperties": false,
      "properties": {
        "approval_policy": {
          "default": "on_request",
          "title": "Approval Policy",
          "type": "string"
        },
        "backend": {
          "title": "Backend",
          "type": "string"
        },
        "context_artifacts": {
          "items": {
            "type": "string"
          },
          "title": "Context Artifacts",
          "type": "array"
        },
        "existing_thread_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Existing Thread Id"
        },
        "network_access": {
          "default": false,
          "title": "Network Access",
          "type": "boolean"
        },
        "output_schema": {
          "title": "Output Schema",
          "type": "string"
        },
        "prompt_template": {
          "title": "Prompt Template",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "sandbox": {
          "$ref": "#/$defs/SandboxMode"
        },
        "thread_policy": {
          "default": "new",
          "enum": [
            "new",
            "resume"
          ],
          "title": "Thread Policy",
          "type": "string"
        },
        "timeout_seconds": {
          "default": 1800,
          "title": "Timeout Seconds",
          "type": "integer"
        },
        "worker_id": {
          "title": "Worker Id",
          "type": "string"
        },
        "workspace_path": {
          "default": ".",
          "title": "Workspace Path",
          "type": "string"
        }
      },
      "required": [
        "worker_id",
        "backend",
        "role",
        "sandbox",
        "prompt_template",
        "output_schema"
      ],
      "title": "WorkerRequestData",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_type": {
      "$ref": "#/$defs/ArtifactType"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/WorkerRequestData"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/ArtifactInput"
      },
      "title": "Inputs",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/ArtifactMetadata"
    },
    "producer": {
      "$ref": "#/$defs/Producer"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactStatus"
        },
        {
          "type": "string"
        }
      ],
      "title": "Status"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "run_id",
    "revision",
    "status",
    "created_at",
    "producer",
    "data"
  ],
  "title": "WorkerRequestArtifact",
  "type": "object"
}
