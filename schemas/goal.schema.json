{
  "$defs": {
    "ArtifactInput": {
      "additionalProperties": false,
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/ArtifactType"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "revision": {
          "title": "Revision",
          "type": "integer"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "path",
        "revision",
        "sha256"
      ],
      "title": "ArtifactInput",
      "type": "object"
    },
    "ArtifactMetadata": {
      "additionalProperties": false,
      "properties": {
        "content_sha256": {
          "default": "",
          "title": "Content Sha256",
          "type": "string"
        }
      },
      "title": "ArtifactMetadata",
      "type": "object"
    },
    "ArtifactStatus": {
      "enum": [
        "accepted",
        "complete",
        "approved",
        "validated",
        "ready",
        "completed",
        "passed",
        "failed",
        "skipped",
        "ready_for_human_review",
        "human_required"
      ],
      "title": "ArtifactStatus",
      "type": "string"
    },
    "ArtifactType": {
      "enum": [
        "goal",
        "repository_snapshot",
        "specification",
        "execution_plan",
        "task",
        "worker_request",
        "worker_result",
        "integration",
        "gate_report",
        "repair_request",
        "repair_result",
        "review_report",
        "evidence_bundle"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "ExecutionMode": {
      "enum": [
        "auto",
        "solo",
        "pipeline",
        "parallel"
      ],
      "title": "ExecutionMode",
      "type": "string"
    },
    "GoalData": {
      "additionalProperties": false,
      "properties": {
        "goal_type": {
          "title": "Goal Type",
          "type": "string"
        },
        "raw_request": {
          "title": "Raw Request",
          "type": "string"
        },
        "requested_mode": {
          "$ref": "#/$defs/ExecutionMode"
        },
        "target_repository": {
          "default": ".",
          "title": "Target Repository",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "user_constraints": {
          "items": {
            "type": "string"
          },
          "title": "User Constraints",
          "type": "array"
        }
      },
      "required": [
        "title",
        "raw_request",
        "goal_type",
        "requested_mode"
      ],
      "title": "GoalData",
      "type": "object"
    },
    "Producer": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/ProducerKind"
        },
        "name": {
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "title": "Producer",
      "type": "object"
    },
    "ProducerKind": {
      "enum": [
        "human",
        "system",
        "model",
        "tool"
      ],
      "title": "ProducerKind",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_type": {
      "$ref": "#/$defs/ArtifactType"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "data": {
      "$ref": "#/$defs/GoalData"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/ArtifactInput"
      },
      "title": "Inputs",
      "type": "array"
    },
    "metadata": {
      "$ref": "#/$defs/ArtifactMetadata"
    },
    "producer": {
      "$ref": "#/$defs/Producer"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactStatus"
        },
        {
          "type": "string"
        }
      ],
      "title": "Status"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "run_id",
    "revision",
    "status",
    "created_at",
    "producer",
    "data"
  ],
  "title": "GoalArtifact",
  "type": "object"
}
